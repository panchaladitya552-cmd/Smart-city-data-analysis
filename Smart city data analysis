        "\n",
        "city_data = [\n",
        "    [\"A1\", 1540, 120],\n",
        "    [\"B2\", 980, 95],\n",
        "    [\"C3\", 2300, 170],\n",
        "    [\"A1\", 1400, 115],\n",
        "    [\"C3\", 2500, 180],\n",
        "    [\"B2\", 1020, 100],\n",
        "    [\"D4\", 800, 85],\n",
        "    [\"E5\", 2600, 190],\n",
        "    [\"A1\", 1600, 130],\n",
        "    [\"C3\", 2100, 160]\n",
        "]\n",
        "\n",
        "\n",
        "junction_data = {}\n",
        "for record in city_data:\n",
        "    junction = record[0]\n",
        "    vehicles = record[1]\n",
        "    aqi = record[2]\n",
        "\n",
        "    if junction not in junction_data:\n",
        "        junction_data[junction] = {\n",
        "            \"vehicles_total\": 0,\n",
        "            \"aqi_total\": 0,\n",
        "            \"count\": 0\n",
        "        }\n",
        "\n",
        "    junction_data[junction][\"vehicles_total\"] += vehicles\n",
        "    junction_data[junction][\"aqi_total\"] += aqi\n",
        "    junction_data[junction][\"count\"] += 1\n",
        "\n",
        "\n",
        "print(\"Total number of records:\", len(city_data))\n",
        "\n",
        "\n",
        "print(\"\\nUnique Junctions:\")\n",
        "for junction in junction_data:\n",
        "    print(junction)\n",
        "\n",
        "\n",
        "highest_avg_aqi = 0\n",
        "highest_avg_vehicle = 0\n",
        "\n",
        "most_polluted = \"\"\n",
        "busiest = \"\"\n",
        "\n",
        "print(\"\\nJunction Analysis:\")\n",
        "\n",
        "for junction in junction_data:\n",
        "\n",
        "    total_vehicles = junction_data[junction][\"vehicles_total\"]\n",
        "    total_aqi = junction_data[junction][\"aqi_total\"]\n",
        "    count = junction_data[junction][\"count\"]\n",
        "\n",
        "    avg_vehicles = total_vehicles / count\n",
        "    avg_aqi = total_aqi / count\n",
        "\n",
        "\n",
        "    if avg_aqi <= 100:\n",
        "        air_quality = \"Good\"\n",
        "    elif avg_aqi <= 150:\n",
        "        air_quality = \"Moderate\"\n",
        "    else:\n",
        "        air_quality = \"Poor\"\n",
        "\n",
        "    print(\"\\nJunction:\", junction)\n",
        "    print(\"Average Vehicles:\", round(avg_vehicles, 2))\n",
        "    print(\"Average AQI:\", round(avg_aqi, 2))\n",
        "    print(\"Air Quality Level:\", air_quality)\n",
        "\n",
        "    # Find most polluted junction\n",
        "    if avg_aqi > highest_avg_aqi:\n",
        "        highest_avg_aqi = avg_aqi\n",
        "        most_polluted = junction\n",
        "\n",
        "    # Find busiest junction\n",
        "    if avg_vehicles > highest_avg_vehicle:\n",
        "        highest_avg_vehicle = avg_vehicles\n",
        "        busiest = junction\n",
        "\n",
        "# 4. Final Results\n",
        "print(\"\\nMost Polluted Junction:\", most_polluted)\n",
        "print(\"Highest Average AQI:\", round(highest_avg_aqi, 2))\n",
        "\n",
        "print(\"\\nBusiest Junction:\", busiest)\n",
        "print(\"Highest Average Vehicle Count:\", round(highest_avg_vehicle, 2))"
